
@using ParqueoCentralWeb.Models
@model List<EspacioModel>
@{
    Layout = "../Shared/_Layout.cshtml";
}

<h1>Historial de movimientos</h1>
<table id="tblMovimientos" class="table table-striped table-hover align-middle w-100">
    <thead class="table-dark">
        <tr>
            <th>Placa</th>
            <th>Espacio</th>
            <th>Entrada</th>
            <th>Salida</th>
            <th>Monto</th>
            <th>Estado</th>
            <th>Usuario</th>
            <th style="width:170px">Acciones</th>
        </tr>
    </thead>
</table>


@section scripts{
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.8/js/dataTables.responsive.min.js"></script>
    <script src="~/Content/JS/Movimientos.js"></script>
}
@section styles{
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.8/css/responsive.dataTables.min.css" />
}