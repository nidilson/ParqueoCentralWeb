@model ParqueoCentralWeb.Models.MovimientoEstacionamientoModel

@{
    ViewBag.Title = "Registrar Salida";
}

<h2>Registrar Salida</h2>

@using (Html.BeginForm("Salida", "Movimientos", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm">

        <div class="card-header">
            <h5 class="mb-0">Información del Movimiento</h5>
        </div>

        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">

                <div class="col-md-6 mb-3">
                    @Html.HiddenFor(m => m.IdMovimiento)
                    @Html.HiddenFor(m => m.IdVehiculo)
                    @Html.HiddenFor(m => m.IdEspacio)
                    @Html.HiddenFor(m => m.EstadoMovimiento)

                    <label for="txtPlaca" class="form-label">
                        Placa
                    </label>

                    <div class="input-group">
                        @Html.TextBoxFor(m => m.Placa,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Ingrese la placa"
                            })

                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="btnBuscarPlaca">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>

                    @Html.ValidationMessageFor(m => m.IdVehiculo, "", new { @class = "text-danger" })

                    <div id="VehiculoNoEncontradoDiv" class="col-md-6 mb-3 visually-hidden">
                        @Html.Label("No se encuentra una entrada registrada para el vehículo", new { @class = "form-label text-danger" })
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 col-xl-4 mb-3">
                    @Html.Label("Propietario", new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.Propietario,
                        new
                        {
                            @class = "form-control",
                            maxlength = "50",
                            @readonly = "Readonly"
                        })

                </div>
                <div class="col-md-6 col-xl-4 mb-3">
                    @Html.Label("Tipo de Vehiculo", new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.TipoVehiculo,
                        new
                        {
                            @class = "form-control",
                            maxlength = "50",
                            @readonly = "Readonly"
                        })

                </div>
                <div class="col-md-6 col-xl-4 mb-3">
                    @Html.Label("Espacio", new { @class = "form-label" })

                    @Html.TextBoxFor(m => m.CodigoEspacio,
                            new
                            {
                                @class = "form-control",
                                @readonly = "readonly"
                            })

                    @Html.ValidationMessageFor(m => m.IdEspacio, "", new { @class = "text-danger" })
                </div>
            </div>
            <hr />
            <div class="row">
                <div class="col-md-6 col-xl-4 mb-3">
                    @Html.Label("Hora de Entrada", new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.FechaHoraEntrada,
                        "{0:yyyy-MM-ddTHH:mm}",
                        new
                        {
                            @class = "form-control",
                            type = "datetime-local",
                            @readonly = "readonly"
                        })



                </div>
                <div class="col-md-6 col-xl-4 mb-3">
                    @Html.Label("Hora de Salida", new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.FechaHoraSalida,
                        "{0:yyyy-MM-ddTHH:mm}",
                        new
                        {
                            @class = "form-control",
                            type = "datetime-local",
                            @readonly = "readonly"
                        })

                </div>
                <div class="col-md-6 col-xl-4 mb-3">
                    @Html.Label("Tiempo Transcurrido", new { @class = "form-label" })

                    <input type="text"
                           id="TiempoTranscurrido"
                           class="form-control"
                           readonly />

                </div>

            </div>

            <div class="row align-items-center justify-content-center" >

                <div class="card border-primary text-primary col-md-6">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center w-100">
                        @Html.Label("Monto total a pagar", new { @class = "form-label fs-5 text-uppercase fw-bold" })

                        <span id="MontoCobradoSpan" class="fw-bold fs-3">
                            @String.Format("₡ {0:N2}", Model == null ? 0 : Model.MontoCobrado)
                        </span>

                        @Html.HiddenFor(m => m.MontoCobrado)
                        <span class="fs-6 text-secondary">Tarifa por hora: <strong>¢500</strong></span>

                        <div class="row gap-2 w-100 d-flex justify-content-center align-items-center">
                            <button id="botonRegistrar" type="submit" class="btn btn-primary col-8" disabled>
                                Registrar Salida
                            </button>

                            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-danger col-3" })

                        </div>
                    </div>
                </div>                

            </div>            

        </div>

    </div>
}

@section Scripts{
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Content/JS/Salida.js"></script>
}
