@model ParqueoCentralWeb.Models.MovimientoEstacionamientoModel

@{
    ViewBag.Title = "Registrar Movimiento";
}

<h2>Registrar Movimiento</h2>

@using (Html.BeginForm("Entrada", "Movimientos", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm">

        <div class="card-header">
            <h5 class="mb-0">Información del Movimiento</h5>
        </div>

        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">

                <div class="col-md-6 mb-3">
                    @Html.HiddenFor(m => m.IdVehiculo)
                    @Html.HiddenFor(m => m.EstadoMovimiento)

                    <label for="txtPlaca" class="form-label">
                        Placa
                    </label>

                    <div class="input-group">
                        @Html.TextBoxFor(m => m.Placa,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Ingrese la placa"
                            })

                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="btnBuscarPlaca">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>

                    @Html.ValidationMessageFor(m => m.IdVehiculo, "", new { @class = "text-danger" })

                    <div id="VehiculoNoEncontradoDiv" class="col-md-6 mb-3 visually-hidden">
                        @Html.Label("No se encuentra el vehículo ¿desea agregarlo?", new { @class = "form-label text-danger" })

                        @Html.ActionLink("Agregar", "Create", "Vehiculos", null, new { @class = "btn btn-success" })
                    </div>
                    <div id="VehiculoIngresadoDiv" class="col-md-6 mb-3 visually-hidden">
                        @Html.Label("Este Vehículo ya tiene una entrada registrada", new { @class = "form-label text-danger" })
                    </div>
                </div>
            </div>
            <hr />
            <div class="row">
                <div class="col-md-6 mb-3">
                    @Html.Label("Propietario", new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.Propietario,
                        new
                        {
                            @class = "form-control",
                            maxlength = "50",
                            @readonly = "Readonly"
                        })

                </div>
                <div class="col-md-6 mb-3">
                    @Html.Label("Tipo de Vehiculo", new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.TipoVehiculo,
                        new
                        {
                            @class = "form-control",
                            maxlength = "50",
                            @readonly = "Readonly"
                        })                                       

                </div>              

            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                @Html.Label("Espacio", new { @class = "form-label" })

                @Html.DropDownListFor(
                    m => m.IdEspacio,
                    (SelectList)ViewBag.Espacios,
                    "-- Seleccione un espacio --",
                    new { @class = "form-select" })

                @Html.ValidationMessageFor(m => m.IdEspacio, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6 mb-3">
                    @Html.LabelFor(m => m.FechaHoraEntrada, new { @class = "form-label" })

                    @Html.TextBoxFor(
                        m => m.FechaHoraEntrada,
                        "{0:yyyy-MM-ddTHH:mm}",
                        new
                        {
                            @class = "form-control disabled",
                            type = "datetime-local",
                            @readonly = "readonly"
                        })

                    @Html.ValidationMessageFor(m => m.FechaHoraEntrada, "", new { @class = "text-danger" })
                </div>          

            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.UsuarioRegistro, new { @class = "form-label" })

                @Html.TextBoxFor(
                    m => m.UsuarioRegistro,
                    new
                    {
                        @class = "form-control",
                        maxlength = "50"
                    })

                @Html.ValidationMessageFor(m => m.UsuarioRegistro, "", new { @class = "text-danger" })
            </div>

        </div>

        <div class="card-footer text-end">

            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })

            <button type="submit" class="btn btn-primary">
                Guardar
            </button>

        </div>

    </div>
}

@section Scripts{
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Content/JS/Entrada.js"></script>
}

