
@{
    ViewBag.Title = "Inicio";
}


<h1>
    Bienvenido, @ViewBag.Operador
</h1>
<p><i class="bi bi-calendar me-2 text-secondary"></i><span class="text-secondary">@DateTime.Now.ToString()</span></p>
<div class="row">

    <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card card-dashboard h-100">
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <i class="bi bi-calendar-check p-3 text-success"></i>
                <span class="text-secondary fw-bold fs-5">Espacios Disponibles</span>
                <span class="fw-bold fs-2">@ViewBag.EspaciosDisponibles</span>
            </div>

        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card card-dashboard h-100">
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <i class="bi bi-ban-fill p-3 text-danger"></i>
                <span class="text-secondary fw-bold fs-5">Espacios Ocupados</span>
                <span class="fw-bold fs-2">@ViewBag.EspaciosOcupados</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card card-dashboard h-100">
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <i class="bi bi-car-front-fill p-3 text-primary"></i>
                <span class="text-secondary fw-bold fs-5">Vehiculos en el parqueo</span>
                <span class="fw-bold fs-2">@ViewBag.Vehiculos</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card card-dashboard h-100">
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <i class="bi bi-arrow-down-up p-3 text-secondary"></i>
                <span class="text-secondary fw-bold fs-5">Movimientos del día</span>
                <span class="fw-bold fs-2">@ViewBag.Movimientos</span>
            </div>
        </div>
    </div>
</div>
<div class="row my-3">
    <div class="col-12">
        <div class="card card-dashboard h-100">
            <div class="card-header">
                <h2>Últimos vehículos ingresados</h2>
            </div>
            <div class="card-body">
                <table id="tblParqueos" class="table table-striped table-hover align-middle w-100">
                    <thead class="table-dark">
                        <tr>
                            <th>Placa</th>
                            <th>Espacio</th>
                            <th>Hora de Entrada</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                </table>

        </div>
    </div>
</div>
    @section scripts{
        <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js"></script>
        <script src="https://cdn.datatables.net/responsive/3.0.8/js/dataTables.responsive.min.js"></script>
        <script src="~/Content/JS/Home.js"></script>
    }
    @section styles{
        <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.css" />
        <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.8/css/responsive.dataTables.min.css" />
    }
