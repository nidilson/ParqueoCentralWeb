
@model ParqueoCentralWeb.Models.EspacioModel

@{
    Layout = "../Shared/_Layout.cshtml";
    ViewBag.Title = "Detalle del Espacio";
}

<h2>Detalle del Vehículo</h2>

<div class="card">
    <div class="card-header">
        <h4>Información del Vehículo</h4>
    </div>

    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.CodigoEspacio)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.CodigoEspacio)
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.TipoEspacio)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.TipoEspacio)
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.Estado)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.Estado)
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.Activo)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.Activo)
            </div>
        </div>

    </div>

    <div class="card-footer">
        @Html.ActionLink("Editar", "Edit", new { id = Model.IdEspacio }, new { @class = "btn btn-warning" })
        @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })
    </div>
</div>

