@using ParqueoCentralWeb.Models
@model List<EspacioModel>
@{
    Layout = "../Shared/_Layout.cshtml";
}

<h1>Espacios</h1>
<a class="btn btn-success" href="~/Espacios/Create">Agregar</a>

<table id="tblEspacios" class="table table-striped table-hover align-middle w-100">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Tipo</th>
            <th>Estado</th>
            <th>Activo</th>
            <th style="width:180px">Acciones</th>
        </tr>
    </thead>
</table>

<div class="modal fade" id="modalEliminarEspacio" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    Eliminar espacio
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                ¿Está seguro de eliminar este espacio de estacionamiento?
            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <a id="btnConfirmarEliminarEspacio"
                   class="btn btn-danger">
                    Eliminar
                </a>

            </div>

        </div>
    </div>
</div>

@section scripts{
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.8/js/dataTables.responsive.min.js"></script>
    <script src="~/Content/JS/Espacios.js"></script>
}
@section styles{
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.8/css/responsive.dataTables.min.css" />
}