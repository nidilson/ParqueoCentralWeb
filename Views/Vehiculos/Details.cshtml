
@model ParqueoCentralWeb.Models.VehiculoModel

@{
    Layout = "../Shared/_Layout.cshtml";
    ViewBag.Title = "Detalle del Vehículo";
}

<h2>Detalle del Vehículo</h2>

<div class="card">
    <div class="card-header">
        <h4>Información del Vehículo</h4>
    </div>

    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.Placa)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.Placa)
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.TipoVehiculo)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.TipoVehiculo)
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.Propietario)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.Propietario)
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(m => m.Contacto)</strong>
            </div>
            <div class="col-md-9">
                @Html.DisplayFor(m => m.Contacto)
            </div>
        </div>

    </div>

    <div class="card-footer">
        @Html.ActionLink("Editar", "Edit", new { id = Model.IdVehiculo }, new { @class = "btn btn-warning" })
        @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })
    </div>
</div>
